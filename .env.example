# .env.example
# Скопируйте этот файл в .env и заполните значениями

# ============================================
# ОБЩИЕ НАСТРОЙКИ
# ============================================
COMPOSE_PROJECT_NAME=documentflow

# ============================================
# MySQL DATABASE CONFIGURATION
# ============================================
MYSQL_ROOT_PASSWORD=your-secure-root-password
MYSQL_DATABASE=DocumentFlowDB
MYSQL_USER=admin
MYSQL_PASSWORD=your-secure-admin-password
MYSQL_PORT=3307

# ============================================
# ASP.NET CORE API CONFIGURATION
# ============================================
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:80
WEB_API_PORT=5189
CONTAINER_API_PORT=80

# ============================================
# JWT TOKEN SETTINGS
# ============================================
# Сгенерируйте новые ключи!
# Можно использовать: openssl rand -base64 64
JWT_SECRET_KEY=GENERATE-NEW-SECRET-KEY-HERE
JWT_EXPIRES_DAYS=7
JWT_ISSUER=DocumentFlowAPI
JWT_AUDIENCE=DocumentFlowAPIClient
JWT_EXPIRES_MINUTES=90

REFRESH_TOKEN_SECRET_KEY=GENERATE-NEW-REFRESH-TOKEN-KEY-HERE
REFRESH_TOKEN_EXPIRES_DAYS=1

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_PASSWORD=your-secure-redis-password
REDIS_PORT=6379

# ============================================
# DEVELOPMENT OVERRIDES
# ============================================
# Раскомментируйте для разработки:
# ASPNETCORE_ENVIRONMENT=Development
# ML_LOG_LEVEL=DEBUG